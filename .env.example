PG_DSN=postgresql://iwm:iwm@localhost:5432/iwm_rag

# Ollama serves BOTH the chat model and the embedding model.
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# Embedding model. Must be pulled in Ollama first (`ollama pull <name>`).
# Pick one — the vector store is auto-migrated on startup when you switch,
# but you MUST re-ingest every report afterwards (vectors from different
# models live in incompatible spaces).
#
#   nomic-embed-text:latest   (768d,  274 MB) — requires search_document:/search_query: prefixes
#   mxbai-embed-large:latest  (1024d, 669 MB) — no prefixes, strong general-purpose model
#   qwen3-embedding:4b        (2560d, 2.5 GB) — largest, best quality on domain text
EMBED_MODEL=nomic-embed-text:latest
# Embedding batch size and concurrency.  Tune for your GPU:
#   EMBED_BATCH       — texts per API call (default 128)
#   EMBED_CONCURRENCY — parallel batch requests (default 8)
#   EMBED_LOCAL_URL   — fallback endpoint if the primary is unreachable
# EMBED_BATCH=128
# EMBED_CONCURRENCY=8
# EMBED_LOCAL_URL=http://localhost:11434

# Available models selectable in the UI. Must be pulled in Ollama first.
# Format: comma-separated model_id:Label pairs. First is the default.
# AVAILABLE_MODELS=llama3.1:8b:Llama 3.1 8B,gemma4:26b:Gemma 4 26B

# Optional. The chain falls through to these only when Ollama fails.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Parallel map-phase summarisation — LLM chunks sent at once (default 6).
# SUMMARY_CONCURRENCY=6

# Retrieval chunking strategy. Pick one:
#   char     — fixed-size sliding window + overlap (default, no model needed)
#   heading  — splits at markdown heading boundaries for thematic coherence
#   semantic — LLM detects topic shifts, best coherence but slower ingestion
# CHUNKING_STRATEGY=char

# Cross-encoder reranker. Sits between RRF fusion and generation —
# reads query+passage *together* and scores relevance far more accurately
# than cosine or RRF alone.
#
# LOCAL MODE (default when RERANK_BASE_URL is empty or starts with "local://"):
#   Loads bge-reranker-v2-m3 in-process via FlagEmbedding.
#   First query pays a one-time ~5 s model-load cost.
#
# CLUSTER MODE (recommended — no cold-start delay):
#   Run rerank_server.py on a machine with the model pre-loaded:
#     pip install flask sentence-transformers
#     python rerank_server.py
#   Then point RERANK_BASE_URL at it:
RERANK_BASE_URL=
# RERANK_LOCAL_MODEL=BAAI/bge-reranker-v2-m3

# Vision-language model for image captioning and OCR.  Must be pulled first:
#   ollama pull qwen3-vl:8b
# VISION_ENABLED=1
# VISION_MODEL=qwen3-vl:8b   # model id in Ollama
# VISION_BASE_URL=            # defaults to LLM_BASE_URL — set if VLM is on a
#                             # different host (e.g. GPU cluster)
